{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/gallery", "dest": "/gallery.html" },
    { "src": "/process", "dest": "/process.html" },
    { "src": "/financing", "dest": "/financing.html" },
    { "src": "/testimonials", "dest": "/testimonials.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/faq", "dest": "/faq.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}